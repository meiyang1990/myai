# 火山引擎 豆包大模型 API 配置
# 请在火山引擎控制台获取以下信息：https://console.volcengine.com/ark

# 火山引擎 API Key（必填）
VOLCENGINE_API_KEY=your-api-key-here

# 火山引擎 API Base URL（必填）
# 默认为火山方舟北京区域接入点
VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎推理接入点 ID，即模型的 endpoint（必填）
# 在火山方舟控制台 -> 在线推理 -> 创建推理接入点后获取
# 例如: ep-20240901xxxxx-xxxxx
VOLCENGINE_MODEL_ENDPOINT=your-endpoint-id-here

# 可选配置
# 生成注释时的温度参数，值越低结果越稳定，默认 0.3
# TEMPERATURE=0.3

# 单次请求最大 token 数，默认 4096
# MAX_TOKENS=4096

# ========== 项目上下文分析配置（可选） ==========

# 智能采样文件数量上限，默认 20
# CONTEXT_SAMPLE_FILE_LIMIT=20

# 采样文件总字符预算（约 4000 token），默认 8000
# CONTEXT_CHAR_BUDGET=8000

# 单个采样文件截取最大行数，默认 200
# CONTEXT_FILE_MAX_LINES=200

# 项目概要缓存有效期（天），超过后提示刷新，默认 7
# CONTEXT_CACHE_EXPIRE_DAYS=7

# 项目上下文缓存目录名称，默认 .code_context
# CONTEXT_CACHE_DIR_NAME=.code_context
